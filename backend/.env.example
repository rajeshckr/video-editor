# -----------------------------------------------------------------------------
# CutStudio Backend - Environment Variables Template
# -----------------------------------------------------------------------------
# Copy this file to '.env' and modify the values as needed for your environment.
# DO NOT commit your actual '.env' file to version control.

# The port the backend server will listen on
PORT=3001

# Comma-separated frontend origins allowed by CORS
# Example: FRONTEND_URL=https://app.yourdomain.com,https://yourdomain.com
# Local example: FRONTEND_URL=http://localhost:5173,http://localhost:4200,http://127.0.0.1:5173
FRONTEND_URL=http://localhost:5173,http://localhost:4200,http://127.0.0.1:5173,http://127.0.0.1:4200,http://www.example.com,http://example.com

# Maximum allowable file upload size in megabytes
MAX_FILE_SIZE_MB=2048

# How long to keep temporary intermediate files and renders (in hours) before cleanup
CLEANUP_RETENTION_HOURS=48

# OpenAI API key for AI-powered features (metadata generation, etc.)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override paths. If left blank, these default to the TMP/ and Tools/ 
# folders at the root of the project directory.
# TOOLS_PATH=C:\path\to\Tools
# TMP_PATH=C:\path\to\TMP
