{
  "name": "cutstudio-installer",
  "version": "1.0.0",
  "description": "CutStudio Video Editor – Local Backend Service",
  "main": "main.js",
  "scripts": {
    "start":     "electron .",
    "build":     "electron-builder --win",
    "build:dir": "electron-builder --win --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.cutstudio.app",
    "productName": "CutStudio",
    "copyright":   "Copyright © 2024 CutStudio",
    "directories": {
      "output":          "dist",
      "buildResources":  "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "settings.html",
      "assets/**"
    ],
    "extraResources": [
      { "from": "../backend",          "to": "backend"            },
      { "from": "../Tools",            "to": "Tools"              },
      { "from": "../frontend/dist",    "to": "frontend",
        "filter": ["**/*"]             }
    ],
    "win": {
      "target": "nsis",
      "icon":   "assets/icon.png"
    },
    "nsis": {
      "oneClick":                        false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut":           true,
      "createStartMenuShortcut":         true,
      "runAfterFinish":                  true,
      "deleteAppDataOnUninstall":        false
    }
  }
}
